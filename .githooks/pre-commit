#!/bin/sh
# Pre-commit gate for Rotometrics.
#
# Prettier owns formatting here (eslint-config-prettier disables stylistic ESLint
# rules), so `eslint` alone will NOT catch formatting drift. Both checks must pass
# before a commit lands. On failure this hook prints the exact command to fix it.

failed=0

echo "pre-commit › prettier --check"
if ! npm run --silent format:check; then
  echo
  echo "  ✗ Formatting issues found. Fix with:"
  echo "      npm run format"
  echo
  failed=1
fi

echo "pre-commit › eslint"
if ! npm run --silent lint; then
  echo
  echo "  ✗ Lint issues found. Auto-fix what's fixable with:"
  echo "      npm run lint:fix"
  echo "  (remaining errors must be fixed by hand, then re-stage and re-commit)"
  echo
  failed=1
fi

if [ "$failed" -ne 0 ]; then
  echo "pre-commit › blocked — run the command(s) above, then 'git add' and commit again."
  exit 1
fi

echo "pre-commit › ok"
